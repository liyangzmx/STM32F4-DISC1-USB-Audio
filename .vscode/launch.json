{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F407-DISC-Audio (ST-LINK)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "stlink",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/STM32F407-DISC-Audio.elf",
      "device": "STM32F407VG",
      "interface": "swd",
      "runToEntryPoint": "main",
      "preLaunchTask": "CMake: build Debug",
      "gdbPath": "/opt/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
      "serverpath": "/opt/ST/STM32CubeCLT_1.21.0/STLink-gdb-server/bin/ST-LINK_gdbserver",
      "stm32cubeprogrammer": "/opt/ST/STM32CubeCLT_1.21.0/STM32CubeProgrammer/bin",
      "svdFile": "/opt/ST/STM32CubeCLT_1.21.0/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
      "showDevDebugOutput": "raw"
    },
    {
      "name": "Attach STM32F407-DISC-Audio (ST-LINK)",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "stlink",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/STM32F407-DISC-Audio.elf",
      "device": "STM32F407VG",
      "interface": "swd",
      "gdbPath": "/opt/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
      "serverpath": "/opt/ST/STM32CubeCLT_1.21.0/STLink-gdb-server/bin/ST-LINK_gdbserver",
      "stm32cubeprogrammer": "/opt/ST/STM32CubeCLT_1.21.0/STM32CubeProgrammer/bin",
      "svdFile": "/opt/ST/STM32CubeCLT_1.21.0/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
      "showDevDebugOutput": "raw"
    }
  ]
}
